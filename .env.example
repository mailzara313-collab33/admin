# ============================================================
# eShop Environment Configuration — EXAMPLE FILE
# ============================================================
# Copy this file to .env and fill in real values.
# .env is excluded from git (.gitignore).
# On production (cPanel): set these via Software > PHP Environment Variables.
# NEVER commit .env with real credentials.
# ============================================================

APP_NAME=Eshop

# CodeIgniter environment: development | testing | production
CI_ENV=production

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
DB_HOST=localhost
DB_USER=your_db_username
DB_PASS=your_db_password_here
DB_NAME=your_db_name

# ----------------------------------------------------------
# JWT — generate with: openssl rand -hex 32
# ----------------------------------------------------------
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ----------------------------------------------------------
# Ion Auth session hash — generate with: openssl rand -hex 32
# ----------------------------------------------------------
ION_AUTH_SESSION_HASH=REPLACE_WITH_64_CHAR_HEX_STRING

# ----------------------------------------------------------
# Firebase (optional — for push notifications)
# ----------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
